---
import { Image } from "astro:assets";
import Logo from "@public/logo.png";

interface Props {
  /** CTA表示を省略するか */
  hideCta?: boolean;
}

const { hideCta = false } = Astro.props;
---

<footer class="bg-[#111827]">
  {/* CTAセクション */}
  {
    !hideCta && (
      <div class="bg-[#0F172A] py-16 px-5 md:px-20">
        <div class="max-w-4xl mx-auto text-center flex flex-col items-center gap-8">
          <h2 class="text-2xl md:text-[32px] font-extrabold text-white">
            クリエイターの"つくりたい"を、一緒に。
          </h2>
          <p class="text-gray-400 text-base">
            ゲームを作りたい方も、制作を依頼したい方も、お気軽にどうぞ。
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href="https://nologic.app/?utm_source=creatorpot&utm_medium=referral&utm_campaign=corporate_site&utm_content=footer_cta"
              class="inline-flex items-center justify-center px-9 py-4 bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-[15px] rounded-[10px] transition-colors min-w-[220px]"
            >
              ゲームを作ってみる
            </a>
            <a
              href="https://discord.gg/3hy2UNmXca"
              class="inline-flex items-center justify-center px-9 py-4 bg-white/10 hover:bg-white/20 text-emerald-500 font-semibold text-[15px] rounded-[10px] border border-emerald-500/40 transition-colors min-w-[220px]"
            >
              コミュニティに参加
            </a>
            <a
              href="/techplantstudio#contact"
              class="inline-flex items-center justify-center px-9 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold text-[15px] rounded-[10px] border border-white/20 transition-colors min-w-[220px]"
            >
              制作のご相談
            </a>
          </div>
        </div>
      </div>
    )
  }

  {/* フッター下部 */}
  <div class="px-5 md:px-20 py-8">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        {/* ロゴ */}
        <div class="flex items-center gap-2.5">
          <Image
            src={Logo}
            alt="クリエイターのうえきばち"
            width={62}
            height={56}
            class="w-auto h-7"
          />
          <span class="text-white text-sm font-semibold"
            >クリエイターのうえきばち</span
          >
        </div>

        {/* リンク */}
        <div class="flex flex-col md:flex-row items-center gap-4 md:gap-6">
          <a
            href="https://nologic.app/?utm_source=creatorpot&utm_medium=referral&utm_campaign=corporate_site&utm_content=footer_text"
            class="text-gray-400 hover:text-white text-[13px] transition-colors"
            >NoLogic</a
          >
          <a
            href="https://discord.gg/3hy2UNmXca"
            class="text-gray-400 hover:text-white text-[13px] transition-colors"
            >NextCreators</a
          >
          <a
            href="/techplantstudio#contact"
            class="text-gray-400 hover:text-white text-[13px] transition-colors"
            >お問い合わせ</a
          >
          <a
            href="/privacy"
            class="text-gray-400 hover:text-white text-[13px] transition-colors"
            >プライバシーポリシー</a
          >
        </div>

        {/* SNS */}
        <div class="flex items-center gap-4">
          <a
            href="https://twitter.com/creator_pot"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"
              ></path></svg
            >
          </a>
          <a
            href="https://note.com/creator_pot"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg
            >
          </a>
        </div>
      </div>

      {/* コピーライト */}
      <div class="text-center mt-8 pt-8 border-t border-gray-800">
        <p class="text-gray-500 text-xs">
          &copy; {new Date().getFullYear()} 株式会社クリエイターのうえきばち All
          rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
