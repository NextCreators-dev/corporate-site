---
import { SEO } from "astro-seo";

// Google Search Console 認証コード（Netlify等の環境変数で設定）
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
// GA4 測定ID（例: G-XXXXXXXXXX）。環境変数で設定されていない場合はタグを出力しない
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<SEO
    title="株式会社クリエイターのうえきばち"
    description="株式会社クリエイターのうえきばちは、ノーコードでゲーム制作ができるプラットフォームの開発や、クリエイターコミュニティ運営を手掛けています。"
    charset="utf-8"
    openGraph={{
        basic: {
            title: "株式会社クリエイターのうえきばち",
            type: "website",
            image: import.meta.env.SITE + "/OGP.png",
            url: "https://corporate-site.com",
        },
    }}
    twitter={{
        creator: "@creator_pot",
    }}
    extend={{
        link: [
            {
                rel: "icon",
                href: "/favicon.ico",
            },
        ],
        meta: [
            ...(gscVerification
                ? [{ name: "google-site-verification", content: gscVerification }]
                : []),
        ],
    }}
/>

{
    gaMeasurementId && (
        <>
            <script
                is:inline
                async
                src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
            />
            <script is:inline define:vars={{ gaMeasurementId }}>
                window.dataLayer = window.dataLayer || [];
                function gtag() {
                    window.dataLayer.push(arguments);
                }
                window.gtag = gtag;
                gtag("js", new Date());
                gtag("config", gaMeasurementId);
            </script>
        </>
    )
}