---
import { SEO } from "astro-seo";

// Google Search Console 認証コード（Netlify等の環境変数で設定）
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
---

<SEO
    title="株式会社クリエイターのうえきばち"
    description="株式会社クリエイターのうえきばちは、ノーコードでゲーム制作ができるプラットフォームの開発や、クリエイターコミュニティ運営を手掛けています。"
    charset="utf-8"
    openGraph={{
        basic: {
            title: "株式会社クリエイターのうえきばち",
            type: "website",
            image: import.meta.env.SITE + "/OGP.png",
            url: "https://corporate-site.com",
        },
    }}
    twitter={{
        creator: "@creator_pot",
    }}
    extend={{
        link: [
            {
                rel: "icon",
                href: "/favicon.ico",
            },
        ],
        meta: [
            ...(gscVerification
                ? [{ name: "google-site-verification", content: gscVerification }]
                : []),
        ],
    }}
/>