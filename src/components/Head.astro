---
import { SEO } from "astro-seo";

// Google Search Console 認証コード（Netlify等の環境変数で設定）
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
// GA4 測定ID（例: G-XXXXXXXXXX）。環境変数で設定されていない場合はタグを出力しない
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<SEO
    title="株式会社クリエイターのうえきばち"
    description="株式会社クリエイターのうえきばちは、ノーコードでゲーム制作ができるプラットフォームの開発や、クリエイターコミュニティ運営を手掛けています。"
    charset="utf-8"
    openGraph={{
        basic: {
            title: "株式会社クリエイターのうえきばち",
            type: "website",
            image: import.meta.env.SITE + "/OGP.png",
            url: "https://corporate-site.com",
        },
    }}
    twitter={{
        creator: "@creator_pot",
    }}
    extend={{
        link: [
            {
                rel: "icon",
                href: "/favicon.ico",
            },
        ],
        meta: [
            ...(gscVerification
                ? [{ name: "google-site-verification", content: gscVerification }]
                : []),
        ],
    }}
/>

<!-- Shippori Mincho 800（ヒーロー H1 専用 / 必要文字のみサブセット）を自己ホスト -->
<!-- レンダーブロックを避けるため preload + インライン @font-face で読み込み、font-display: optional で CLS=0 を担保 -->
<link
    rel="preload"
    href="/fonts/shippori-mincho-800-subset.woff2"
    as="font"
    type="font/woff2"
    crossorigin
/>
<style is:inline>
    @font-face {
        font-family: "Shippori Mincho";
        font-style: normal;
        font-weight: 800;
        font-display: optional;
        src: url("/fonts/shippori-mincho-800-subset.woff2") format("woff2");
    }
</style>

{
    gaMeasurementId && (
        <script is:inline define:vars={{ gaMeasurementId }}>
            // GTM/GA4 を load 後に遅延注入してパフォーマンスへの影響を回避する
            // ページビューは config 呼び出し時点で送信されるため、遅延しても計測は正しく行われる
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                window.dataLayer.push(arguments);
            }
            window.gtag = gtag;
            gtag("js", new Date());
            gtag("config", gaMeasurementId);

            function loadGtag() {
                var s = document.createElement("script");
                s.async = true;
                s.src =
                    "https://www.googletagmanager.com/gtag/js?id=" +
                    gaMeasurementId;
                document.head.appendChild(s);
            }

            // load 後にアイドル時間で読み込み。直帰計測ロスを抑えるため timeout を設定
            function schedule() {
                if ("requestIdleCallback" in window) {
                    window.requestIdleCallback(loadGtag, { timeout: 1500 });
                } else {
                    setTimeout(loadGtag, 200);
                }
            }
            if (document.readyState === "complete") {
                schedule();
            } else {
                window.addEventListener("load", schedule, { once: true });
            }
        </script>
    )
}
