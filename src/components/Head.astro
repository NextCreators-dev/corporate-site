---
import { SEO } from "astro-seo";

// Google Search Console 認証コード（Netlify等の環境変数で設定）
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
// GA4 測定ID（例: G-XXXXXXXXXX）。環境変数で設定されていない場合はタグを出力しない
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<SEO
    title="株式会社クリエイターのうえきばち"
    description="株式会社クリエイターのうえきばちは、ノーコードでゲーム制作ができるプラットフォームの開発や、クリエイターコミュニティ運営を手掛けています。"
    charset="utf-8"
    openGraph={{
        basic: {
            title: "株式会社クリエイターのうえきばち",
            type: "website",
            image: import.meta.env.SITE + "/OGP.png",
            url: "https://corporate-site.com",
        },
    }}
    twitter={{
        creator: "@creator_pot",
    }}
    extend={{
        link: [
            {
                rel: "icon",
                href: "/favicon.ico",
            },
        ],
        meta: [
            ...(gscVerification
                ? [{ name: "google-site-verification", content: gscVerification }]
                : []),
        ],
    }}
/>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- Shippori Mincho はヒーロー H1 のみで使用（weight:800 / 文字サブセット） -->
<link
    href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@800&text=%E8%AA%B0%E3%82%82%E3%81%8C%E5%89%B5%E4%BD%9C%E3%81%AB%E6%8C%91%E6%88%A6%E3%81%A7%E3%81%8D%E3%82%8B%E4%B8%96%E7%95%8C%E3%81%AE%E5%AE%9F%E7%8F%BE&display=swap"
    rel="stylesheet"
/>

{
    gaMeasurementId && (
        <>
            <script
                is:inline
                async
                src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
            />
            <script is:inline define:vars={{ gaMeasurementId }}>
                window.dataLayer = window.dataLayer || [];
                function gtag() {
                    window.dataLayer.push(arguments);
                }
                window.gtag = gtag;
                gtag("js", new Date());
                gtag("config", gaMeasurementId);
            </script>
        </>
    )
}
