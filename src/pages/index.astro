<script>
  // テキストアニメーション
  // data-anim-stagger 属性を持つ親要素の配下にある .anim-char を対象に、
  // 各文字を CJK統合漢字 のランダム文字で 6回切り替えてから最終文字に着地させる
  const TICKS = 6;
  const STEP_MS = 50;

  const randomKanji = () => {
    const code = 0x4e00 + Math.floor(Math.random() * (0x9fff - 0x4e00));
    return String.fromCodePoint(code);
  };

  const animateTextGroups = () => {
    const groups = document.querySelectorAll<HTMLElement>(
      "[data-anim-stagger]",
    );
    if (groups.length === 0) return;

    // モーション低減設定の場合はアニメーションせず、最終文字のまま表示
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    groups.forEach((group) => {
      const stagger = Number(group.dataset.animStagger) || 25;
      const chars = group.querySelectorAll<HTMLElement>(".anim-char");
      chars.forEach((el, i) => {
        const target = el.dataset.char ?? el.textContent ?? "";
        const startDelay = i * stagger;
        for (let t = 0; t < TICKS; t++) {
          window.setTimeout(
            () => {
              el.textContent = randomKanji();
            },
            startDelay + t * STEP_MS,
          );
        }
        window.setTimeout(
          () => {
            el.textContent = target;
          },
          startDelay + TICKS * STEP_MS,
        );
      });
    });
  };

  // DOM 構築後に開始
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", animateTextGroups);
  } else {
    animateTextGroups();
  }
</script>

