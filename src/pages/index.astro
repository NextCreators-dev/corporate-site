---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import Navigation from "@components/Navigation.astro";
import Footer from "@components/Footer.astro";
import nextCreatorLogo from "@public/nextcreator-logo.png";
import CEOPhoto from "@public/ceo-photo.png";
import heroBg from "../assets/hero-bg.png";
import { newsItems } from "../data/news";
---

<Layout title="株式会社クリエイターのうえきばち">
  <main class="bg-[#0A0F1C] text-white">
    <!-- ヘッダー -->
    <Navigation />

    <!-- Hero Section -->
    <section
      class="relative min-h-screen overflow-hidden bg-[#020B16] pt-24 pb-8 md:pt-28"
    >
      <!-- 背景画像 (Astro Image で WebP/AVIF を自動生成し、優先読み込み) -->
      <Image
        src={heroBg}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        formats={["avif", "webp"]}
        loading="eager"
        fetchpriority="high"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <!-- 文字可読性確保用の暗色オーバーレイ -->
      <div class="absolute inset-0 bg-black/60"></div>

      <div
        class="relative z-10 mx-auto flex min-h-[calc(100vh-7rem)] max-w-[1140px] flex-col justify-between px-5 md:px-0"
      >
        <div
          class="grid flex-1 items-center gap-8 lg:grid-cols-[640px_minmax(420px,1fr)]"
        >
          <div class="max-w-[900px] pt-8 md:pt-12 lg:pt-10">
            <h1
              class="hero-mincho text-[34px] font-extrabold leading-[1.52] tracking-[0.08em] text-white drop-shadow-[0_6px_18px_rgba(255,255,255,0.14)] md:text-[52px] lg:text-[64px]"
              data-anim-stagger="25"
            >
              {
                ["誰もが", "創作に挑戦できる", "世界の実現"].map((line) => (
                  <span class="block whitespace-nowrap">
                    {Array.from(line).map((ch) => (
                      <span class="anim-char" data-char={ch}>
                        {ch}
                      </span>
                    ))}
                  </span>
                ))
              }
            </h1>
            <p
              class="mt-7 max-w-[590px] text-[14px] font-bold leading-[2.05] tracking-[0.13em] text-white/[0.9] md:text-[15px]"
              data-anim-stagger="10"
            >
              {
                Array.from(
                  "テクノロジーの力で、つくることのハードルを下げ、",
                ).map((ch) => (
                  <span class="anim-char" data-char={ch}>
                    {ch}
                  </span>
                ))
              }<br class="hidden md:block" />
              {
                Array.from("アイデアをカタチにする喜びをすべての人に。").map(
                  (ch) => (
                    <span class="anim-char" data-char={ch}>
                      {ch}
                    </span>
                  ),
                )
              }<br />
              {
                Array.from("わたしたちは、創作の可能性をひらき、").map((ch) => (
                  <span class="anim-char" data-char={ch}>
                    {ch}
                  </span>
                ))
              }<br class="hidden md:block" />
              {
                Array.from(
                  "誰もがクリエイターになれる世界を実現していきます。",
                ).map((ch) => (
                  <span class="anim-char" data-char={ch}>
                    {ch}
                  </span>
                ))
              }
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
              <a
                href="#vision"
                class="inline-flex min-w-[220px] items-center justify-center gap-5 rounded-full border border-emerald-400 px-7 py-3.5 text-[15px] font-bold text-emerald-300 transition-colors hover:bg-emerald-400 hover:text-[#052016]"
              >
                私たちについて
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                  ></path></svg
                >
              </a>
              <a
                href="/essay"
                class="inline-flex min-w-[240px] items-center justify-center gap-5 rounded-full border border-white/25 bg-white/[0.08] px-7 py-3.5 text-[15px] font-bold text-white transition-colors hover:border-white/50 hover:bg-white/20"
              >
                クリエイターの皆様へ
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                  ></path></svg
                >
              </a>
            </div>
          </div>

          <div
            class="relative mx-auto hidden h-[330px] w-full max-w-[420px] items-center justify-center md:flex md:h-[440px] md:max-w-[500px] lg:-mr-10 lg:-mt-10 lg:h-[540px] lg:max-w-none"
          >
            <img
              src="/crebachi-logo.png"
              alt=""
              class="relative h-[280px] w-[280px] object-contain md:h-[360px] md:w-[360px] lg:h-[400px] lg:w-[400px]"
              loading="eager"
            />
          </div>
        </div>

        <div class="grid gap-4 pb-7 md:grid-cols-3 md:gap-4">
          <div
            class="flex min-h-[120px] items-center gap-5 rounded-[10px] border border-white/[0.13] bg-white/[0.055] px-5 py-4 shadow-[0_24px_80px_rgba(0,0,0,0.32)] backdrop-blur-xl"
          >
            <span
              class="flex h-[72px] w-[72px] flex-shrink-0 items-center justify-center rounded-[4px] bg-[#06111F] text-emerald-400 shadow-inner shadow-white/5"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="34"
                height="34"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.65"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="m21 16-9 5-9-5V8l9-5 9 5Z"></path><path
                  d="m3.3 7.7 8.7 4.8 8.7-4.8"></path><path d="M12 22V12"
                ></path></svg
              >
            </span>
            <span>
              <span
                class="block text-[16px] font-black leading-relaxed tracking-[0.04em] text-white"
                >ノーコードゲーム制作プラットフォームの開発</span
              >
            </span>
          </div>
          <div
            class="flex min-h-[120px] items-center gap-5 rounded-[10px] border border-white/[0.13] bg-white/[0.055] px-5 py-4 shadow-[0_24px_80px_rgba(0,0,0,0.32)] backdrop-blur-xl"
          >
            <span
              class="flex h-[72px] w-[72px] flex-shrink-0 items-center justify-center rounded-[4px] bg-[#06111F] text-emerald-400 shadow-inner shadow-white/5"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="34"
                height="34"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.65"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                ></path><circle cx="9" cy="7" r="4"></circle><path
                  d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                  d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
              >
            </span>
            <span>
              <span
                class="block text-[16px] font-black leading-relaxed tracking-[0.04em] text-white"
                >クリエイターコミュニティの運営</span
              >
            </span>
          </div>
          <div
            class="flex min-h-[120px] items-center gap-5 rounded-[10px] border border-white/[0.13] bg-white/[0.055] px-5 py-4 shadow-[0_24px_80px_rgba(0,0,0,0.32)] backdrop-blur-xl"
          >
            <span
              class="flex h-[72px] w-[72px] flex-shrink-0 items-center justify-center rounded-[4px] bg-[#06111F] text-emerald-400 shadow-inner shadow-white/5"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="34"
                height="34"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.65"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="m16 18 6-6-6-6"></path><path d="m8 6-6 6 6 6"
                ></path></svg
              >
            </span>
            <span>
              <span
                class="block text-[16px] font-black leading-relaxed tracking-[0.04em] text-white"
                >受託開発</span
              >
            </span>
          </div>
        </div>
      </div>

      <div
        class="absolute bottom-12 right-8 hidden flex-col items-center gap-4 text-emerald-400 xl:flex"
      >
        <span
          class="[writing-mode:vertical-rl] text-[11px] font-black tracking-[0.28em]"
          >SCROLL</span
        >
        <span class="h-11 w-px bg-emerald-400"></span>
      </div>
    </section>

    <!-- News Section -->
    <section
      class="bg-[#111827] border-y border-[#1E293B] py-12 px-5 md:px-[120px]"
    >
      <div class="max-w-7xl mx-auto flex flex-col gap-6">
        <div class="flex flex-col items-center gap-4">
          <div
            class="inline-flex items-center gap-1.5 bg-emerald-500 text-white text-xs font-bold px-4 py-1.5 rounded-full tracking-wider"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="m3 11 18-5v12L3 13v-2z"></path><path
                d="M11.6 16.8a3 3 0 1 1-5.8-1.6"></path></svg
            >
            NEWS
          </div>
          <a
            href="/news"
            class="flex items-center gap-1.5 text-emerald-500 text-[13px] font-medium hover:underline"
          >
            一覧を見る
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
            >
          </a>
        </div>
        <div class="flex flex-col">
          {
            newsItems.slice(0, 3).map((item, i) => (
              <a
                href={`/news/${item.slug}`}
                class={`flex flex-col md:flex-row md:items-center gap-3 md:gap-6 py-5 hover:bg-white/[0.02] transition-colors -mx-4 px-4 rounded ${i < newsItems.slice(0, 3).length - 1 ? "border-b border-[#1E293B]" : ""}`}
              >
                <span class="text-gray-500 text-[13px] font-medium">
                  {item.date}
                </span>
                <span class="inline-flex w-fit items-center px-3 py-1 bg-emerald-500/10 text-emerald-500 text-[11px] font-semibold rounded border border-emerald-500/20">
                  {item.category}
                </span>
                <span class="text-white text-[15px] font-medium">
                  {item.title}
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Metrics Section -->
    <section class="bg-[#111827] py-[60px] px-5 md:px-[120px]">
      <div class="max-w-7xl mx-auto flex flex-col items-center gap-10">
        <div
          class="inline-flex items-center px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]"
        >
          TRACK RECORD
        </div>
        <div
          class="flex flex-col md:flex-row items-center justify-center w-full gap-8 md:gap-0"
        >
          <div class="flex flex-1 flex-col items-center gap-2">
            <span class="text-emerald-500 text-5xl font-black">200+</span>
            <span class="text-gray-400 text-[15px] font-medium"
              >オリジナルゲームが誕生</span
            >
          </div>
          <div class="hidden md:block w-px h-[60px] bg-[#1E293B] flex-shrink-0">
          </div>
          <div class="flex flex-1 flex-col items-center gap-2">
            <span class="text-emerald-500 text-5xl font-black">100+</span>
            <span class="text-gray-400 text-[15px] font-medium"
              >クリエイターが参加中</span
            >
          </div>
          <div class="hidden md:block w-px h-[60px] bg-[#1E293B] flex-shrink-0">
          </div>
          <div class="flex flex-1 flex-col items-center gap-2">
            <span class="text-emerald-500 text-5xl font-black">5</span>
            <span class="text-gray-400 text-[15px] font-medium">連携企業数</span
            >
          </div>
        </div>
      </div>
    </section>

    <!-- NoLogic Section -->
    <section id="product" class="bg-[#0A0F1C] py-[100px] px-5 md:px-[120px]">
      <div class="max-w-7xl mx-auto flex flex-col items-center gap-[60px]">
        {/* エッセイへのリンクボタン */}
        <a
          href="/essay"
          class="inline-flex items-center gap-2 px-7 py-3 bg-white/10 hover:bg-white/15 text-white font-semibold text-sm rounded-full border border-white/20 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 20h9"></path><path
              d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"
            ></path></svg
          >
          クリエイターに向けたメッセージ
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-gray-400"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>

        {/* バッジ */}
        <div
          class="inline-flex items-center px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]"
        >
          PRODUCT
        </div>

        <h2
          class="text-3xl md:text-4xl font-extrabold text-center max-w-[900px]"
        >
          NoLogic — ノーコードゲーム制作プラットフォーム
        </h2>
        <p class="text-white/90 text-xl font-medium text-center">
          「ゲームを作りたいけど、コードは書けない」を解決する
        </p>
        <p
          class="text-gray-400 text-[17px] leading-relaxed text-center max-w-[800px]"
        >
          プログラミングができなくても大丈夫。あなたのイラスト1枚が、遊べるゲームになります。<br
          />
          作ったゲームはSNSでシェア・公開できます。アップロードした作品の著作権はあなたのものです。
        </p>

        {/* ステップ */}
        <div
          class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full max-w-[1100px]"
        >
          <div
            class="flex flex-col items-center gap-5 bg-[#111827] p-8 rounded-2xl border border-[#1E293B]"
          >
            <div
              class="flex items-center justify-center w-12 h-12 bg-emerald-500 rounded-full text-white text-xl font-bold"
            >
              1
            </div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#10B981"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
              ></path><polyline points="17 8 12 3 7 8"></polyline><line
                x1="12"
                x2="12"
                y1="3"
                y2="15"></line></svg
            >
            <h3 class="text-white text-lg font-bold text-center">
              イラストをアップロード
            </h3>
            <p class="text-gray-400 text-sm text-center leading-relaxed">
              お手持ちのイラストや写真をドラッグ&ドロップ
            </p>
          </div>
          <div
            class="flex flex-col items-center gap-5 bg-[#111827] p-8 rounded-2xl border border-[#1E293B]"
          >
            <div
              class="flex items-center justify-center w-12 h-12 bg-emerald-500 rounded-full text-white text-xl font-bold"
            >
              2
            </div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#10B981"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="18" height="7" x="3" y="3" rx="1"></rect><rect
                width="9"
                height="7"
                x="3"
                y="14"
                rx="1"></rect><rect width="5" height="7" x="16" y="14" rx="1"
              ></rect></svg
            >
            <h3 class="text-white text-lg font-bold text-center">
              テンプレートを選ぶ
            </h3>
            <p class="text-gray-400 text-sm text-center leading-relaxed">
              豊富なゲームテンプレートから好きなジャンルを選択
            </p>
          </div>
          <div
            class="flex flex-col items-center gap-5 bg-[#111827] p-8 rounded-2xl border border-[#1E293B]"
          >
            <div
              class="flex items-center justify-center w-12 h-12 bg-emerald-500 rounded-full text-white text-xl font-bold"
            >
              3
            </div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#10B981"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="6" x2="10" y1="11" y2="11"></line><line
                x1="8"
                x2="8"
                y1="9"
                y2="13"></line><line x1="15" x2="15.01" y1="12" y2="12"
              ></line><line x1="18" x2="18.01" y1="10" y2="10"></line><path
                d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"
              ></path></svg
            >
            <h3 class="text-white text-lg font-bold text-center">
              ゲーム完成！すぐに公開
            </h3>
            <p class="text-gray-400 text-sm text-center leading-relaxed">
              自動でゲームが生成され、SNSでシェア・公開できる
            </p>
          </div>
        </div>

        <a
          href="https://nologic.app"
          class="inline-flex items-center gap-2.5 px-12 py-[18px] bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-base rounded-xl transition-colors"
        >
          イラストをアップして試してみる
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </div>
    </section>

    <!-- NextCreators Section -->
    <section id="community" class="bg-[#111827] py-[100px] px-5 md:px-[120px]">
      <div class="max-w-7xl mx-auto flex flex-col items-center gap-[60px]">
        <div
          class="inline-flex items-center px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]"
        >
          COMMUNITY
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-center">
          NextCreators — クリエイター交流Discordサーバー
        </h2>
        <p class="text-white/90 text-xl font-medium text-center">
          ひとりで創り続ける孤独、もう終わりにしませんか。
        </p>
        <p
          class="text-gray-400 text-[17px] leading-relaxed text-center max-w-[700px]"
        >
          作品を見せる相手がいない、モチベが続かない...そんな悩みを持つ100名以上のクリエイターが集まっています。<br
          />
          初心者歓迎、見学だけでもOKです。
        </p>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 w-full">
          {/* メリットカード */}
          <div class="flex flex-col gap-6">
            <div class="flex gap-4 bg-[#0A0F1C] p-6 rounded-xl">
              <div
                class="flex-shrink-0 w-12 h-12 bg-emerald-500/15 rounded-xl flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#10B981"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                  ></path><circle cx="9" cy="7" r="4"></circle><path
                    d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                    d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
                >
              </div>
              <div>
                <h4 class="text-white font-bold mb-1.5">作品の共有</h4>
                <p class="text-gray-400 text-sm">
                  制作中の作品を気軽に投稿。仲間からリアルなフィードバックがもらえる。
                </p>
              </div>
            </div>
            <div class="flex gap-4 bg-[#0A0F1C] p-6 rounded-xl">
              <div
                class="flex-shrink-0 w-12 h-12 bg-emerald-500/15 rounded-xl flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
