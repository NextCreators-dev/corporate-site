---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import Navigation from "@components/Navigation.astro";
import Footer from "@components/Footer.astro";
import heroBg from "@public/hero-bg.png";
import noLogicLogo from "@public/nologic-logo.png";
import nextCreatorLogo from "@public/nextcreator-logo.png";
import CEOPhoto from "@public/ceo-photo.png";
import { newsItems } from "../data/news";
---

<Layout title="株式会社クリエイターのうえきばち">
  <main class="bg-[#0A0F1C] text-white">
    <!-- ヘッダー -->
    <Navigation />

    <!-- Hero Section -->
    <section class="relative min-h-[720px] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0">
        <Image
          src={heroBg}
          width={1920}
          height={1080}
          alt="クリエイティブな背景"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="absolute inset-0 bg-[#0A0F1C]/60"></div>
      <div class="relative z-10 flex flex-col items-center text-center px-5 py-24 gap-6 max-w-[900px]">
        <p class="text-emerald-500 font-medium text-lg tracking-wider">
          ゲームを作りたいのに、コードが書けない人へ。
        </p>
        <h1 class="text-4xl md:text-[56px] font-black leading-tight">
          イラスト1枚で、あなたのキャラが<br />ゲームになる。
        </h1>
        <p class="text-white/80 text-base md:text-[17px] leading-relaxed max-w-[700px]">
          プログラミング不要。テンプレートを選んで、キャラをアップロードするだけ。<br />
          無料で、今日から始められます。
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 mt-4">
          <div class="flex flex-col items-center gap-2">
            <a
              href="https://nologic.app"
              class="inline-flex items-center justify-center gap-2.5 w-[280px] py-[18px] bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-lg rounded-xl transition-colors"
            >
              無料で今すぐ試す
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <span class="text-white/50 text-xs">登録不要・5分で完成</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <a
              href="https://discord.gg/3hy2UNmXca"
              class="inline-flex items-center justify-center gap-2.5 w-[280px] py-[18px] bg-white/10 hover:bg-white/20 text-emerald-500 font-semibold text-lg rounded-xl border border-emerald-500/40 transition-colors"
            >
              仲間を見つける（Discord）
            </a>
            <span class="text-white/50 text-xs">ROM専OK・初心者歓迎</span>
          </div>
        </div>
      </div>
    </section>

    <!-- News Section -->
    <section class="bg-[#111827] border-y border-[#1E293B] py-12 px-5 md:px-[120px]">
      <div class="max-w-7xl mx-auto flex flex-col gap-6">
        <div class="flex flex-col items-center gap-4">
          <div class="inline-flex items-center gap-1.5 bg-emerald-500 text-white text-xs font-bold px-4 py-1.5 rounded-full tracking-wider">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 13v-2z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>
            NEWS
          </div>
          <a href="/news" class="flex items-center gap-1.5 text-emerald-500 text-[13px] font-medium hover:underline">
            一覧を見る
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
        <div class="flex flex-col">
          {newsItems.slice(0, 3).map((item, i) => (
            <a
              href={`/news/${item.slug}`}
              class={`flex flex-col md:flex-row md:items-center gap-3 md:gap-6 py-5 hover:bg-white/[0.02] transition-colors -mx-4 px-4 rounded ${i < newsItems.slice(0, 3).length - 1 ? 'border-b border-[#1E293B]' : ''}`}
            >
              <span class="text-gray-500 text-[13px] font-medium">{item.date}</span>
              <span class="inline-flex w-fit items-center px-3 py-1 bg-emerald-500/10 text-emerald-500 text-[11px] font-semibold rounded border border-emerald-500/20">{item.category}</span>
              <span class="text-white text-[15px] font-medium">{item.title}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Metrics Section -->
    <section class="bg-[#111827] py-[60px] px-5 md:px-[120px]">
      <div class="max-w-7xl mx-auto flex flex-col items-center gap-10">
        <div class="inline-flex items-center px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]">
          TRACK RECORD
        </div>
        <div class="flex flex-col md:flex-row items-center justify-around w-full gap-8">
          <div class="flex flex-col items-center gap-2">
            <span class="text-emerald-500 text-5xl font-black">200+</span>
            <span class="text-gray-400 text-[15px] font-medium">オリジナルゲームが誕生</span>
          </div>
          <div class="hidden md:block w-px h-[60px] bg-[#1E293B]"></div>
          <div class="flex flex-col items-center gap-2">
            <span class="text-emerald-500 text-5xl font-black">100+</span>
            <span class="text-gray-400 text-[15px] font-medium">クリエイターが参加中</span>
          </div>
          <div class="hidden md:block w-px h-[60px] bg-[#1E293B]"></div>
          <div class="flex flex-col items-center gap-3">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 rounded-lg border border-emerald-500/20">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
              <span class="text-emerald-500 text-lg font-bold">IPA 未踏事業 採択</span>
            </div>
            <span class="text-gray-400 text-[15px] font-medium">IT人材発掘・育成事業</span>
          </div>
        </div>
      </div>
    </section>

    <!-- NoLogic Section -->
    <section id="product" class="bg-[#0A0F1C] py-[100px] px-5 md:px-[120px]">
      <div class="max-w-7xl mx-auto flex flex-col items-center gap-[60px]">
        {/* エッセイへのリンクボタン */}
        <a href="/essay" class="inline-flex items-center gap-2 px-7 py-3 bg-white/10 hover:bg-white/15 text-white font-semibold text-sm rounded-full border border-white/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
          クリエイターに向けたメッセージ
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        {/* バッジ */}
        <div class="inline-flex items-center px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]">
          PRODUCT
        </div>

        <h2 class="text-3xl md:text-4xl font-extrabold text-center max-w-[900px]">
          NoLogic — ノーコードゲーム制作プラットフォーム
        </h2>
        <p class="text-white/90 text-xl font-medium text-center">
          「ゲームを作りたいけど、コードは書けない」を解決する
        </p>
        <p class="text-gray-400 text-[17px] leading-relaxed text-center max-w-[800px]">
          プログラミングができなくても大丈夫。あなたのイラスト1枚が、遊べるゲームになります。<br />
          作ったゲームはSNSでシェア・公開できます。アップロードした作品の著作権はあなたのものです。
        </p>

        {/* ステップ */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full max-w-[1100px]">
          <div class="flex flex-col items-center gap-5 bg-[#111827] p-8 rounded-2xl border border-[#1E293B]">
            <div class="flex items-center justify-center w-12 h-12 bg-emerald-500 rounded-full text-white text-xl font-bold">1</div>
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
            <h3 class="text-white text-lg font-bold text-center">イラストをアップロード</h3>
            <p class="text-gray-400 text-sm text-center leading-relaxed">お手持ちのイラストや写真をドラッグ&ドロップ</p>
          </div>
          <div class="flex flex-col items-center gap-5 bg-[#111827] p-8 rounded-2xl border border-[#1E293B]">
            <div class="flex items-center justify-center w-12 h-12 bg-emerald-500 rounded-full text-white text-xl font-bold">2</div>
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="7" x="3" y="3" rx="1"/><rect width="9" height="7" x="3" y="14" rx="1"/><rect width="5" height="7" x="16" y="14" rx="1"/></svg>
            <h3 class="text-white text-lg font-bold text-center">テンプレートを選ぶ</h3>
            <p class="text-gray-400 text-sm text-center leading-relaxed">豊富なゲームテンプレートから好きなジャンルを選択</p>
          </div>
          <div class="flex flex-col items-center gap-5 bg-[#111827] p-8 rounded-2xl border border-[#1E293B]">
            <div class="flex items-center justify-center w-12 h-12 bg-emerald-500 rounded-full text-white text-xl font-bold">3</div>
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg>
            <h3 class="text-white text-lg font-bold text-center">ゲーム完成！すぐに公開</h3>
            <p class="text-gray-400 text-sm text-center leading-relaxed">自動でゲームが生成され、SNSでシェア・公開できる</p>
          </div>
        </div>

        {/* ゲームギャラリー */}
        <h3 class="text-white text-[22px] font-bold">NoLogicで作られたゲーム</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 w-full max-w-[1200px]">
          <div class="bg-[#111827] rounded-2xl border border-[#1E293B] overflow-hidden">
            <div class="h-[180px] bg-gradient-to-br from-emerald-900/40 to-[#111827]"></div>
            <div class="p-5">
              <p class="text-white text-[15px] font-semibold">ファンタジークエスト</p>
              <p class="text-gray-500 text-[13px] mt-1">RPG・アドベンチャー</p>
            </div>
          </div>
          <div class="bg-[#111827] rounded-2xl border border-[#1E293B] overflow-hidden">
            <div class="h-[180px] bg-gradient-to-br from-blue-900/40 to-[#111827]"></div>
            <div class="p-5">
              <p class="text-white text-[15px] font-semibold">パズルパラダイス</p>
              <p class="text-gray-500 text-[13px] mt-1">パズル・カジュアル</p>
            </div>
          </div>
          <div class="bg-[#111827] rounded-2xl border border-[#1E293B] overflow-hidden">
            <div class="h-[180px] bg-gradient-to-br from-red-900/40 to-[#111827]"></div>
            <div class="p-5">
              <p class="text-white text-[15px] font-semibold">バトルランナー</p>
              <p class="text-gray-500 text-[13px] mt-1">アクション・プラットフォーマー</p>
            </div>
          </div>
          <div class="bg-[#111827] rounded-2xl border border-[#1E293B] overflow-hidden">
            <div class="h-[180px] bg-gradient-to-br from-purple-900/40 to-[#111827]"></div>
            <div class="p-5">
              <p class="text-white text-[15px] font-semibold">星降る夜の物語</p>
              <p class="text-gray-500 text-[13px] mt-1">ノベル・ストーリー</p>
            </div>
          </div>
        </div>

        <a
          href="https://nologic.app"
          class="inline-flex items-center gap-2.5 px-12 py-[18px] bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-base rounded-xl transition-colors"
        >
          イラストをアップして試してみる
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- NextCreators Section -->
    <section class="bg-[#111827] py-[100px] px-5 md:px-[120px]">
      <div class="max-w-7xl mx-auto flex flex-col items-center gap-[60px]">
        <div class="inline-flex items-center px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]">
          COMMUNITY
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-center">
          NextCreators — クリエイター交流Discordサーバー
        </h2>
        <p class="text-white/90 text-xl font-medium text-center">
          ひとりで創り続ける孤独、もう終わりにしませんか。
        </p>
        <p class="text-gray-400 text-[17px] leading-relaxed text-center max-w-[700px]">
          作品を見せる相手がいない、モチベが続かない——そんな悩みを持つ100名以上のクリエイターが集まっています。<br />
          初心者歓迎、見学だけでもOKです。
        </p>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 w-full">
          {/* メリットカード */}
          <div class="flex flex-col gap-6">
            <div class="flex gap-4 bg-[#0A0F1C] p-6 rounded-xl">
              <div class="flex-shrink-0 w-12 h-12 bg-emerald-500/15 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1.5">作品の共有</h4>
                <p class="text-gray-400 text-sm">制作中の作品を気軽に投稿。仲間からリアルなフィードバックがもらえる。</p>
              </div>
            </div>
            <div class="flex gap-4 bg-[#0A0F1C] p-6 rounded-xl">
              <div class="flex-shrink-0 w-12 h-12 bg-emerald-500/15 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1.5">相談・質問</h4>
                <p class="text-gray-400 text-sm">技術的な質問や創作の悩みを、経験豊富なメンバーに相談できる。</p>
              </div>
            </div>
            <div class="flex gap-4 bg-[#0A0F1C] p-6 rounded-xl">
              <div class="flex-shrink-0 w-12 h-12 bg-emerald-500/15 rounded-xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
              </div>
              <div>
                <h4 class="text-white font-bold mb-1.5">イベント・交流</h4>
                <p class="text-gray-400 text-sm">定期的なイベントや勉強会で、ジャンルを超えた交流ができる。</p>
              </div>
            </div>
          </div>

          {/* コミュニティイメージ */}
          <div class="rounded-2xl overflow-hidden bg-gradient-to-br from-emerald-900/30 to-[#111827] min-h-[380px]">
            <Image
              src={nextCreatorLogo}
              width={540}
              height={540}
              alt="NextCreatorsコミュニティ"
              class="w-full h-full object-cover"
            />
          </div>
        </div>

        <a
          href="https://discord.gg/3hy2UNmXca"
          class="inline-flex items-center gap-2.5 px-12 py-[18px] bg-white/10 hover:bg-white/15 text-emerald-500 font-bold text-base rounded-xl border border-emerald-500/40 transition-colors"
        >
          コミュニティに参加する（無料）
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- TechPlant Studio Section -->
    <section id="services" class="bg-[#0A0F1C] py-[100px] px-5 md:px-[120px]">
      <div class="max-w-7xl mx-auto flex flex-col items-center gap-[60px]">
        <div class="inline-flex items-center px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]">
          SERVICES
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-center">
          TechPlant Studio — 受託開発スタジオ
        </h2>
        <p class="text-white/90 text-xl font-medium text-center">
          ゲーム・Web・AIで、御社のアイデアを形に。
        </p>
        <p class="text-gray-400 text-[17px] leading-relaxed text-center max-w-[700px]">
          ゲームを使ったプロモーション、AIを組み込んだサービス開発——<br />
          企画から納品まで伴走します。まずはお気軽にご相談ください。
        </p>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-5 w-full">
          <div class="flex flex-col gap-4 bg-[#111827] p-7 rounded-2xl border border-[#1E293B]">
            <div class="w-11 h-11 bg-emerald-500/15 rounded-[10px] flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg>
            </div>
            <h3 class="text-white text-base font-bold">ゲーム制作</h3>
            <p class="text-gray-400 text-[13px] leading-relaxed">NoLogicを活用したオリジナルゲームの企画・制作</p>
          </div>
          <div class="flex flex-col gap-4 bg-[#111827] p-7 rounded-2xl border border-[#1E293B]">
            <div class="w-11 h-11 bg-emerald-500/15 rounded-[10px] flex items-center justify-center">
