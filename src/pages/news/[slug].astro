---
import Layout from "@layouts/Layout.astro";
import Footer from "@components/Footer.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";
import { ja } from "date-fns/locale";

export async function getStaticPaths() {
  const newsEntries = await getCollection("news");
  return newsEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// 関連記事（同じタグを持つ記事を最大3件表示）
const allNews = await getCollection("news");
const relatedNews = allNews
  .filter(
    (news) =>
      news.slug !== entry.slug &&
      news.data.tags.some((tag) => entry.data.tags.includes(tag))
  )
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---

<Layout title={`${entry.data.title} | ニュース | 株式会社クリエイターのうえきばち`}>
  <main class="min-h-screen bg-gray-50">
    <!-- Breadcrumb -->
    <section class="bg-white border-b py-4">
      <div class="container px-4 mx-auto">
        <nav class="flex items-center gap-2 text-sm text-gray-600">
          <a href="/" class="hover:text-[#219e9b]">ホーム</a>
          <span>›</span>
          <a href="/news" class="hover:text-[#219e9b]">ニュース</a>
          <span>›</span>
          <span class="text-gray-900">{entry.data.title}</span>
        </nav>
      </div>
    </section>

    <!-- Article Header -->
    <section class="py-12 bg-white">
      <div class="container px-4 mx-auto">
        <article class="max-w-3xl mx-auto">
          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mb-4">
            {
              entry.data.tags.map((tag) => (
                <a
                  href={`/news?tag=${encodeURIComponent(tag)}`}
                  class="px-3 py-1 bg-[#219e9b] bg-opacity-10 text-[#219e9b] rounded-full text-sm hover:bg-opacity-20 transition-colors"
                >
                  {tag}
                </a>
              ))
            }
          </div>

          <!-- Title -->
          <h1 class="text-4xl md:text-3xl font-bold mb-4">
            {entry.data.title}
          </h1>

          <!-- Meta Info -->
          <div class="flex flex-wrap items-center gap-4 text-gray-600 mb-8">
            <time class="flex items-center gap-2">
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
              {format(entry.data.publishedAt, "yyyy年MM月dd日", { locale: ja })}
            </time>
            <span class="flex items-center gap-2">
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                ></path>
              </svg>
              {entry.data.author}
            </span>
          </div>

          <!-- Description -->
          <p class="text-xl text-gray-700 mb-8 pb-8 border-b">
            {entry.data.description}
          </p>

          <!-- Content -->
          <div class="prose prose-lg max-w-none">
            <Content />
          </div>
        </article>
      </div>
    </section>

    <!-- Related News -->
    {
      relatedNews.length > 0 && (
        <section class="py-12 bg-white border-t">
          <div class="container px-4 mx-auto">
            <div class="max-w-3xl mx-auto">
              <h2 class="text-2xl font-bold mb-6">関連記事</h2>
              <div class="grid md:grid-cols-3 gap-6">
                {relatedNews.map((news) => (
                  <a
                    href={`/news/${news.slug}`}
                    class="group bg-gray-50 rounded-lg p-4 hover:shadow-md transition-shadow"
                  >
                    <div class="flex flex-wrap gap-1 mb-2">
                      {news.data.tags.slice(0, 2).map((tag) => (
                        <span class="px-2 py-1 bg-[#219e9b] bg-opacity-10 text-[#219e9b] rounded text-xs">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <h3 class="font-bold mb-2 group-hover:text-[#219e9b] transition-colors line-clamp-2">
                      {news.data.title}
                    </h3>
                    <time class="text-sm text-gray-500">
                      {format(news.data.publishedAt, "yyyy年MM月dd日", {
                        locale: ja,
                      })}
                    </time>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- Back to News List -->
    <section class="py-12 bg-gray-50">
      <div class="container px-4 mx-auto text-center">
        <a
          href="/news"
          class="inline-block px-8 py-3 text-lg font-semibold text-white bg-[#219e9b] hover:bg-[#1a7e7c] rounded-lg transition-colors"
        >
          ← ニュース一覧へ戻る
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Markdown Content Styling */
  .prose {
    color: #374151;
  }

  .prose h2 {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #111827;
  }

  .prose h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #111827;
  }

  .prose p {
    margin-bottom: 1rem;
    line-height: 1.75;
  }

  .prose ul,
  .prose ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose a {
    color: #219e9b;
    text-decoration: underline;
  }

  .prose a:hover {
    color: #1a7e7c;
  }

  .prose strong {
    font-weight: 600;
    color: #111827;
  }

  .prose code {
    background-color: #f3f4f6;
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .prose pre {
    background-color: #1f2937;
    color: #f9fafb;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
    color: inherit;
  }

  .prose blockquote {
    border-left: 4px solid #219e9b;
    padding-left: 1rem;
    margin-left: 0;
    margin-bottom: 1rem;
    color: #6b7280;
    font-style: italic;
  }

  .prose img {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .prose hr {
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }

  .prose th,
  .prose td {
    border: 1px solid #e5e7eb;
    padding: 0.75rem;
    text-align: left;
  }

  .prose th {
    background-color: #f9fafb;
    font-weight: 600;
  }
</style>
