---
import Layout from "@layouts/Layout.astro";
import Navigation from "@components/Navigation.astro";
import Footer from "@components/Footer.astro";
import { newsItems } from "../../data/news";

export function getStaticPaths() {
  return newsItems.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<Layout title={`${item.title} | 株式会社クリエイターのうえきばち`}>
  <main class="bg-[#0A0F1C] text-white">
    <Navigation showBack={true} />

    <!-- 記事ヘッダー -->
    <section class="bg-[#111827] py-20 px-5 md:px-[120px]">
      <div class="max-w-4xl mx-auto flex flex-col items-center gap-6 text-center pt-16">
        <div class="inline-flex items-center gap-1.5 px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 13v-2z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>
          NEWS
        </div>
        <div class="flex items-center gap-4">
          <span class="text-gray-500 text-[13px] font-medium">{item.date}</span>
          <span class="inline-flex items-center px-3 py-1 bg-emerald-500/10 text-emerald-500 text-[11px] font-semibold rounded border border-emerald-500/20">
            {item.category}
          </span>
        </div>
        <h1 class="text-2xl md:text-[36px] font-black leading-tight">
          {item.title}
        </h1>
      </div>
    </section>

    <!-- 記事本文 -->
    <section class="bg-[#0A0F1C] py-16 px-5 md:px-[120px]">
      <div class="max-w-4xl mx-auto">
        <article class="article-body max-w-none text-[#C0C8D4] text-base leading-[2]">
          <Fragment set:html={item.content} />
        </article>

        <!-- 一覧に戻る -->
        <div class="mt-16 pt-8 border-t border-[#1E293B]">
          <a
            href="/news"
            class="inline-flex items-center gap-2 text-emerald-500 text-sm font-medium hover:underline"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            お知らせ一覧に戻る
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* 記事本文の見出し・リスト・強調などのタイポグラフィ */

  /* 段落 */
  .article-body :global(p) {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .article-body :global(p:first-child) {
    margin-top: 0;
  }

  /* h2（本文内で使用する場合のセクション見出し） */
  .article-body :global(h2) {
    position: relative;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    padding-left: 1rem;
    color: #ffffff;
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1.5;
    border-left: 4px solid #10b981;
  }
  @media (min-width: 768px) {
    .article-body :global(h2) {
      font-size: 1.75rem;
    }
  }

  /* h3（小見出し） */
  .article-body :global(h3) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.5;
  }
  .article-body :global(h3)::before {
    content: "";
    display: inline-block;
    width: 6px;
    height: 22px;
    background: linear-gradient(180deg, #10b981 0%, #059669 100%);
    border-radius: 3px;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .article-body :global(h3) {
      font-size: 1.375rem;
    }
  }

  /* h4（詳細な小見出し） */
  .article-body :global(h4) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #ffffff;
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.5;
  }

  /* 箇条書き（ul） */
  .article-body :global(ul) {
    margin: 1.25rem 0;
    padding: 1.25rem 1.5rem;
    background: rgba(16, 185, 129, 0.04);
    border: 1px solid rgba(16, 185, 129, 0.15);
    border-radius: 0.75rem;
    list-style: none;
  }
  .article-body :global(ul li) {
    position: relative;
    padding-left: 1.5rem;
    margin: 0.5rem 0;
    line-height: 1.9;
  }
  .article-body :global(ul li)::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.9em;
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    transform: translateY(-50%);
  }

  /* 番号付きリスト（ol） */
  .article-body :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.75rem;
    list-style: decimal;
  }
  .article-body :global(ol li) {
    margin: 0.5rem 0;
    padding-left: 0.5rem;
    line-height: 1.9;
  }
  .article-body :global(ol li::marker) {
    color: #10b981;
    font-weight: 700;
  }

  /* 強調（strong） */
  .article-body :global(strong) {
    color: #ffffff;
    font-weight: 700;
    background: linear-gradient(transparent 60%, rgba(16, 185, 129, 0.18) 60%);
    padding: 0 2px;
  }

  /* リンク（a） */
  .article-body :global(a) {
    color: #10b981;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 150ms ease;
  }
  .article-body :global(a:hover) {
    color: #34d399;
  }

  /* インラインコード（code） */
  .article-body :global(code) {
    background: rgba(16, 185, 129, 0.1);
    color: #6ee7b7;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
  }

  /* 引用（blockquote） */
  .article-body :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 3px solid #10b981;
    background: rgba(255, 255, 255, 0.02);
    color: #94a3b8;
    font-style: italic;
  }

  /* 区切り線（hr） */
  .article-body :global(hr) {
    margin: 2.5rem 0;
    border: none;
    border-top: 1px solid #1e293b;
  }
</style>
