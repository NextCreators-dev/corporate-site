---
import Layout from "@layouts/Layout.astro";
import Footer from "@components/Footer.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";
import { ja } from "date-fns/locale";

// すべてのニュースを取得
const allNews = await getCollection("news");
const sortedNews = allNews.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// URLパラメータから検索条件を取得
const url = Astro.url;
const searchQuery = url.searchParams.get("q") || "";
const selectedTag = url.searchParams.get("tag") || "";

// すべてのタグを抽出
const allTags = Array.from(
  new Set(allNews.flatMap((news) => news.data.tags))
).sort();

// フィルタリング
let filteredNews = sortedNews;

if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredNews = filteredNews.filter(
    (news) =>
      news.data.title.toLowerCase().includes(query) ||
      news.data.description.toLowerCase().includes(query)
  );
}

if (selectedTag) {
  filteredNews = filteredNews.filter((news) =>
    news.data.tags.includes(selectedTag)
  );
}
---

<Layout title="ニュース | 株式会社クリエイターのうえきばち">
  <main class="min-h-screen bg-gray-50">
    <!-- Header -->
    <section class="bg-[#219e9b] text-white py-16">
      <div class="container px-4 mx-auto">
        <h1 class="text-5xl md:text-4xl font-bold text-center">ニュース</h1>
        <p class="text-xl md:text-lg text-center mt-4">
          最新のお知らせや情報をお届けします
        </p>
      </div>
    </section>

    <!-- Search and Filter Section -->
    <section class="py-8 bg-white border-b">
      <div class="container px-4 mx-auto">
        <div class="max-w-4xl mx-auto">
          <!-- Keyword Search -->
          <form method="GET" class="mb-6">
            <div class="flex gap-2">
              <input
                type="text"
                name="q"
                value={searchQuery}
                placeholder="キーワードで検索..."
                class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#219e9b]"
              />
              <button
                type="submit"
                class="px-6 py-3 bg-[#219e9b] hover:bg-[#1a7e7c] text-white font-semibold rounded-lg transition-colors"
              >
                検索
              </button>
              {
                (searchQuery || selectedTag) && (
                  <a
                    href="/news"
                    class="px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold rounded-lg transition-colors"
                  >
                    クリア
                  </a>
                )
              }
            </div>
          </form>

          <!-- Tag Filter -->
          <div>
            <h3 class="text-lg font-semibold mb-3">タグで絞り込み</h3>
            <div class="flex flex-wrap gap-2">
              {
                allTags.map((tag) => (
                  <a
                    href={`/news?tag=${encodeURIComponent(tag)}`}
                    class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${
                      selectedTag === tag
                        ? "bg-[#219e9b] text-white"
                        : "bg-gray-200 text-gray-700 hover:bg-gray-300"
                    }`}
                  >
                    {tag}
                  </a>
                ))
              }
            </div>
          </div>

          <!-- Search Results Info -->
          {
            (searchQuery || selectedTag) && (
              <div class="mt-6 p-4 bg-blue-50 rounded-lg">
                <p class="text-gray-700">
                  {filteredNews.length}件の記事が見つかりました
                  {searchQuery && ` (キーワード: "${searchQuery}")`}
                  {selectedTag && ` (タグ: ${selectedTag})`}
                </p>
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- News List -->
    <section class="py-12">
      <div class="container px-4 mx-auto">
        <div class="max-w-4xl mx-auto">
          {
            filteredNews.length === 0 ? (
              <div class="text-center py-12">
                <p class="text-xl text-gray-600">
                  該当する記事が見つかりませんでした。
                </p>
              </div>
            ) : (
              <div class="space-y-6">
                {filteredNews.map((news) => (
                  <a
                    href={`/news/${news.slug}`}
                    class="block group bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow p-6"
                  >
                    <div class="flex flex-wrap gap-2 mb-3">
                      {news.data.tags.map((tag) => (
                        <span class="px-3 py-1 bg-[#219e9b] bg-opacity-10 text-[#219e9b] rounded-full text-sm">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <h2 class="text-2xl font-bold mb-3 group-hover:text-[#219e9b] transition-colors">
                      {news.data.title}
                    </h2>
                    <p class="text-gray-600 mb-4">{news.data.description}</p>
                    <div class="flex justify-between items-center text-sm text-gray-500">
                      <time>
                        {format(news.data.publishedAt, "yyyy年MM月dd日", {
                          locale: ja,
                        })}
                      </time>
                      <span class="text-[#219e9b] group-hover:underline">
                        続きを読む →
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- Back to Home -->
    <section class="py-12 bg-white">
      <div class="container px-4 mx-auto text-center">
        <a
          href="/"
          class="inline-block px-8 py-3 text-lg font-semibold text-white bg-[#219e9b] hover:bg-[#1a7e7c] rounded-lg transition-colors"
        >
          トップページへ戻る
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
