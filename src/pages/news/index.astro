---
import Layout from "@layouts/Layout.astro";
import Navigation from "@components/Navigation.astro";
import Footer from "@components/Footer.astro";
import { newsItems } from "../../data/news";

const categories = [...new Set(newsItems.map((item) => item.category))];
---

<Layout title="お知らせ | 株式会社クリエイターのうえきばち">
  <div class="flex flex-col min-h-screen">
    <main class="bg-[#0A0F1C] text-white flex-1">
      <Navigation showBack={true} />

      <!-- ヘッダー -->
      <section class="bg-[#111827] py-20 px-5 md:px-[120px]">
        <div class="max-w-4xl mx-auto flex flex-col items-center gap-6 text-center pt-16">
          <div class="inline-flex items-center gap-1.5 px-5 py-2 bg-emerald-500/15 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/25 tracking-[2px]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 13v-2z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>
            NEWS
          </div>
          <h1 class="text-3xl md:text-[44px] font-black leading-tight">
            お知らせ
          </h1>
        </div>
      </section>

      <!-- ニュース一覧 -->
      <section class="bg-[#0A0F1C] py-16 px-5 md:px-[120px]">
        <div class="max-w-4xl mx-auto flex flex-col gap-8">
          <!-- カテゴリフィルター -->
          <div class="flex flex-wrap gap-2" id="category-filter">
            <button
              data-category="all"
              class="filter-btn active px-4 py-1.5 text-[13px] font-semibold rounded-full border transition-colors bg-emerald-500 text-white border-emerald-500"
            >
              すべて
            </button>
            {categories.map((cat) => (
              <button
                data-category={cat}
                class="filter-btn px-4 py-1.5 text-[13px] font-semibold rounded-full border transition-colors bg-transparent text-gray-400 border-[#1E293B] hover:border-emerald-500/50 hover:text-emerald-500"
              >
                {cat}
              </button>
            ))}
          </div>

          <!-- 記事リスト -->
          <div class="flex flex-col" id="news-list">
            {newsItems.map((item) => (
              <a
                href={`/news/${item.slug}`}
                data-category={item.category}
                class="news-item flex flex-col md:flex-row md:items-center gap-3 md:gap-6 py-5 border-b border-[#1E293B] hover:bg-white/[0.02] transition-colors -mx-4 px-4 rounded"
              >
                <span class="text-gray-500 text-[13px] font-medium shrink-0 tabular-nums">{item.date}</span>
                <span class="inline-flex items-center justify-center w-[4.5rem] py-1 bg-emerald-500/10 text-emerald-500 text-[11px] font-semibold rounded border border-emerald-500/20 shrink-0">
                  {item.category}
                </span>
                <span class="text-white text-[15px] font-medium">{item.title}</span>
              </a>
            ))}
          </div>

          <!-- 該当なしメッセージ -->
          <p id="no-results" class="hidden text-gray-500 text-sm text-center py-8">
            該当するお知らせはありません。
          </p>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLElement>(".news-item");
  const noResults = document.getElementById("no-results");

  const activeClasses = ["bg-emerald-500", "text-white", "border-emerald-500"];
  const inactiveClasses = ["bg-transparent", "text-gray-400", "border-[#1E293B]", "hover:border-emerald-500/50", "hover:text-emerald-500"];

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category;

      // ボタンのスタイル切り替え
      buttons.forEach((b) => {
        b.classList.remove(...activeClasses);
        b.classList.add(...inactiveClasses);
      });
      btn.classList.remove(...inactiveClasses);
      btn.classList.add(...activeClasses);

      // 記事の表示切り替え
      let visibleCount = 0;
      items.forEach((item) => {
        if (category === "all" || item.dataset.category === category) {
          item.style.display = "";
          visibleCount++;
        } else {
          item.style.display = "none";
        }
      });

      // 該当なしメッセージ
      if (noResults) {
        noResults.classList.toggle("hidden", visibleCount > 0);
      }
    });
  });
</script>
